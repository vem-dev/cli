{
	"name": "@vemdev/cli",
	"version": "0.1.35",
	"description": "Official VEM CLI for project memory workflows.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vem-dev/cli.git"
	},
	"homepage": "https://vem.dev",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org",
		"provenance": true
	},
	"bin": {
		"vem": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"logo.png",
		"LICENSE"
	],
	"scripts": {
		"prebuild": "pnpm --filter @vem/schemas build && pnpm --filter @vem/core build",
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js",
		"test": "vitest",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@sentry/node": "^10.40.0",
		"chalk": "^5.6.2",
		"cli-table3": "^0.6.5",
		"commander": "^14.0.3",
		"find-up-simple": "^1.0.1",
		"fs-extra": "^11.3.3",
		"pino": "^10.3.1",
		"prompts": "^2.4.2"
	},
	"devDependencies": {
		"@types/node": "^25.3.1",
		"@types/prompts": "^2.4.9",
		"@vem/core": "workspace:*",
		"@vem/schemas": "workspace:*",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
